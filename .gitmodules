[submodule "vim/.vim"]
	path = vim/.vim
	url = git@github.com:mgreystone/.vim.git
[submodule "zsh/.config/zsh-git-prompt"]
	path = zsh/.config/zsh-git-prompt
	url = https://github.com/olivierverdier/zsh-git-prompt.git
[submodule "zsh/.oh-my-zsh/custom/themes/powerlevel10k"]
	path = zsh/.oh-my-zsh/custom/themes/powerlevel10k
	url = https://github.com/romkatv/powerlevel10k.git
[submodule "zsh/.config/dircolors-solarized"]
	path = zsh/.config/dircolors-solarized
	url = https://github.com/seebi/dircolors-solarized.git
